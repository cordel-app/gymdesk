{
  "name": "@gymdesk/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "npx node-pg-migrate up --envPath .env --migrations-dir src/infra/migrations --no-lock",
    "db:migrate:down": "npx node-pg-migrate down --envPath .env --migrations-dir src/infra/migrations --no-lock",
    "db:seed": "node -r tsx/cjs src/infra/seed.ts"
  },
  "dependencies": {
    "@clerk/backend": "3.8.4",
    "@clerk/express": "2.1.32",
    "@types/cors": "2.8.19",
    "cors": "2.8.6",
    "dotenv": "16.6.1",
    "express": "4.22.2",
    "node-pg-migrate": "8.0.4",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/express": "4.17.25",
    "@types/node": "20.19.43",
    "@types/pg": "8.20.0",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
}
