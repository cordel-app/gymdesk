{
  "name": "@gymdesk/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "knex migrate:latest --knexfile knexfile.cjs",
    "db:migrate:down": "knex migrate:rollback --knexfile knexfile.cjs",
    "db:seed": "node -r tsx/cjs src/infra/seed.ts"
  },
  "dependencies": {
    "@clerk/backend": "3.8.4",
    "@clerk/express": "2.1.32",
    "dotenv": "16.6.1",
    "express": "4.22.2",
    "knex": "3.1.0",
    "mysql2": "3.15.3",
    "swagger-jsdoc": "6.3.0",
    "swagger-ui-express": "5.0.1"
  },
  "devDependencies": {
    "@types/express": "4.17.25",
    "@types/node": "20.19.43",
    "@types/swagger-jsdoc": "6.0.4",
    "@types/swagger-ui-express": "4.1.8",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
}
