# --- Runtime DB (mysql2 pool in src/infra/db.ts) ---
# HOST accepts "host" or "host:port". Local dev with npm run db:up:
#   CORDEL_FITNESS_DB_HOST=localhost:3306
#   CORDEL_FITNESS_DB_USER=root
#   CORDEL_FITNESS_DB_PASSWORD=fitness
#   CORDEL_FITNESS_DB_NAME=fitness
CORDEL_FITNESS_DB_HOST=host:3306
CORDEL_FITNESS_DB_USER=user
CORDEL_FITNESS_DB_PASSWORD=password
CORDEL_FITNESS_DB_NAME=fitness

# --- Migrations only (knexfile.cjs, one-shot podman run in deploy) ---
# Locally, points at the same DB as above. In prod, injected from the
# DATABASE_URL_MIGRATIONS GitHub secret (DDL-privileged fitness_deploy user).
DATABASE_URL=mysql://root:fitness@localhost:3306/fitness

PORT=3000
CORDEL_FITNESS_ADMIN_URL=http://localhost:8081
CORDEL_FITNESS_MEMBERS_URL=http://localhost:8082
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
# Signing secret for the Clerk webhook (Dashboard → Webhooks → your endpoint).
# Backstops team-invite activation on the `user.created` event.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...
# Used only for the seed script
SEED_USER_ID=
