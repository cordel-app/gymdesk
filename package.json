{
  "name": "gymdesk",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "apps/backoffice",
    "apps/app"
  ],
  "scripts": {
    "dev:backend": "npm --workspace backend run dev",
    "dev:backoffice": "npm --workspace apps/backoffice run dev",
    "dev:app": "npm --workspace apps/app run dev",
    "build:backend": "npm --workspace backend run build",
    "build:backoffice": "npm --workspace apps/backoffice run build",
    "build:app": "npm --workspace apps/app run build",
    "db:up": "docker compose up -d mysql --wait",
    "db:down": "docker compose down",
    "db:migrate": "npm --workspace backend run db:migrate",
    "db:seed": "npm --workspace backend run db:seed",
    "env:pull": "bash scripts/env-pull.sh"
  }
}
