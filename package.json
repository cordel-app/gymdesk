{
  "name": "gymdesk",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "api",
    "apps/admin",
    "apps/member"
  ],
  "scripts": {
    "dev:api": "npm --workspace api run dev",
    "dev:admin": "npm --workspace apps/admin run dev",
    "dev:member": "npm --workspace apps/member run dev",
    "build:api": "npm --workspace api run build",
    "build:admin": "npm --workspace apps/admin run build",
    "build:member": "npm --workspace apps/member run build",
    "db:up": "docker compose up -d mysql --wait",
    "db:down": "docker compose down",
    "db:migrate": "npm --workspace api run db:migrate",
    "db:seed": "npm --workspace api run db:seed"
  },
  "devDependencies": {
    "pg": "^8.22.0"
  }
}
